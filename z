function renderChart(containerId, lblId, data, colors) {
  const c = document.getElementById(containerId);
  const l = document.getElementById(lblId);
  if (!c) return;
  const max = Math.max(...data.map(d => d.val));
  c.innerHTML = data.map((d,i) => `
    <div style="flex:1;display:flex;flex-direction:column;align-items:stretch;justify-content:flex-end;height:100%">
      <div class="chart-bar" style="height:${Math.max((d.val/max)*100,4)}%;background:${colors[i%colors.length]};opacity:.85" title="${d.lbl}: ${d.val}"></div>
    </div>`).join('');
  if (l) l.innerHTML = data.map(d => `<div style="font-size:9px;color:var(--text3);text-align:center;flex:1">${d.lbl}<br><strong style="color:var(--text2)">${d.val}</strong></div>`).join('');
}

