      <div style="display:flex;align-items:center;justify-content:space-between">
        <div style="display:flex;gap:-4px">
          ${p.team.map(t => `<div style="width:24px;height:24px;border-radius:50%;background:var(--accent-dim);color:var(--accent2);font-size:9px;font-weight:600;border:2px solid var(--surface);display:flex;align-items:center;justify-content:center;margin-right:-6px">${t}</div>`).join('')}
        </div>
        <div style="display:flex;gap:6px">
          <span class="badge badge-gray">📎 ${Math.floor(Math.random()*10+1)} archivos</span>
          <span class="badge badge-gray">💬 ${Math.floor(Math.random()*30+1)} comentarios</span>
          <button class="btn btn-ghost btn-xs" onclick="goTo('seguimiento',document.querySelector('[onclick*=seguimiento]'))">Ver detalle →</button>
        </div>
      </div>
    </div>`).join('');
}

function renderQuejas() {
  const el = document.getElementById('quejas-list');
  if (!el) return;
  const tipoBadge = {'Queja':'badge-red','Sugerencia':'badge-green','Denuncia':'badge-amber'};
  const estadoBadge = {'En revisión':'badge-amber','Recibida':'badge-blue','Resuelto':'badge-green','Resuelto ✓':'badge-green'};
  el.innerHTML = QUEJAS.map(q => `
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:14px;margin-bottom:10px;cursor:pointer;transition:all var(--transition)" onmouseenter="this.style.borderColor='var(--border2)'" onmouseleave="this.style.borderColor='var(--border)'">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
        <span class="badge ${tipoBadge[q.tipo]}">${q.tipo}</span>
        <div style="font-size:13.5px;font-weight:500;color:var(--text);flex:1">${q.titulo}</div>
        <span class="badge ${estadoBadge[q.estado]||'badge-gray'}">${q.estado}</span>
      </div>
      <div style="font-size:12.5px;color:var(--text2);line-height:1.5;margin-bottom:8px">${q.desc}</div>
      <div style="display:flex;align-items:center;gap:8px">
        <span class="badge badge-gray">${q.categoria}</span>
        ${q.anon ? '<span class="badge badge-gray">🔒 Anónima</span>' : ''}
        <span style="font-size:11px;color:var(--text3);margin-left:auto">${q.fecha} · ${q.id}</span>
      </div>
    </div>`).join('');

  const cats = document.getElementById('quejas-cats');
  if (cats) {
    const catMap = {};
    QUEJAS.forEach(q => { catMap[q.categoria] = (catMap[q.categoria]||0)+1 });
    const max = Math.max(...Object.values(catMap));
    cats.innerHTML = Object.entries(catMap).map(([k,v]) => `
      <div>
        <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px">
          <span style="color:var(--text2)">${k}</span><span style="color:var(--accent2);font-weight:600">${v}</span>
        </div>
        <div class="prog-bar"><div class="prog-fill prog-blue" style="width:${(v/max)*100}%"></div></div>
      </div>`).join('');
  }
}

function renderUsersTable() {
  const tb = document.getElementById('users-table-body');
  if (!tb) return;
  const rolBadge = {'Alumno':'badge-blue','Docente':'badge-green','Administrador':'badge-amber','Director':'badge-purple','SysAdmin':'badge-red'};
  tb.innerHTML = USERS.map(u => `
    <tr>
      <td><strong>${u.name}</strong></td>
      <td><code style="font-size:11px;background:var(--bg3);padding:2px 7px;border-radius:4px;color:var(--text3)">${u.mat}</code></td>
      <td><span class="badge ${rolBadge[u.rol]||'badge-gray'}">${u.rol}</span></td>
      <td>${u.carrera}</td>
      <td><span class="badge ${u.estado==='Activo'?'badge-green':'badge-gray'}">${u.estado}</span></td>
      <td style="color:var(--text3)">${u.acceso}</td>
      <td>
        <div style="display:flex;gap:4px">
          <button class="btn btn-ghost btn-xs" onclick="showToast('Editando usuario: ${u.name}')">Editar</button>
          <button class="btn btn-danger btn-xs" onclick="showToast('Deshabilitando usuario...')">Deshabilitar</button>
        </div>
      </td>
    </tr>`).join('');
}

function renderActivityTable() {
  const tb = document.getElementById('activity-table');
  if (!tb) return;
  tb.innerHTML = ACTIVITY_LOG.map(a => `
    <tr>
      <td style="color:var(--text3);font-size:12px">${a.time}</td>
      <td><strong>${a.user}</strong></td>
      <td>${a.action}</td>
      <td><span class="badge badge-gray">${a.module}</span></td>
      <td style="font-size:11.5px;color:var(--text3)">${a.ip}</td>
      <td><span class="badge ${a.status==='OK'?'badge-green':'badge-red'}">${a.status}</span></td>
    </tr>`).join('');
}

